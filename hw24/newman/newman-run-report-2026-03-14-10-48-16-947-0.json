              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const notifData = pm.response.json() || [];",
                "console.log(\"Notifications:\", JSON.stringify(notifData, null, 2));",
                "",
                "const hasSuccess = notifData.some(n => n.message && n.message.includes('успешно'));",
                "const hasFail = notifData.some(n => n.message && n.message.includes('недостаточно'));",
                "",
                "pm.test(\"Has success notification\", () => pm.expect(hasSuccess).to.be.true);",
                "pm.test(\"Has fail notification\", () => pm.expect(hasFail).to.be.true);",
                "",
                "console.log(\"✅ Success found:\", hasSuccess);",
                "console.log(\"✅ Fail found:\", hasFail);"
              ],
